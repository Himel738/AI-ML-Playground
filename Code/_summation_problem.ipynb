   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "5\n"
     ]
    }
   ],
   "source": [
    "inp = input()\n",
    "numbers = inp.split()\n",
    "\n",
    "x = int (numbers[0])\n",
    "y = int (numbers[1])\n",
    "\n",
    "last_digit_x = x % 10\n",
    "last_digit_y = y % 10\n",
    "print(last_digit_x + last_digit_y)"
   ]
  }
