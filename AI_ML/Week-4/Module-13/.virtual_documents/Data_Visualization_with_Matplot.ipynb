


import numpy as np
import pandas as pd
import matplotlib.pyplot as plt 


hours=[2, 3, 4, 1, 5, 7, 3]
days = [1, 2, 3, 4, 5, 6, 7]
plt.plot(days, hours) # in x-Axis Time -> days and in Y Axis -> hours


plt.xlabel('Days')
plt.ylabel('Study Hours')
plt.title('Trend of a Student Study Time Over a Week')

plt.plot(days, hours)


student_data = {
    "Student_1": [2, 3, 4, 1, 5, 7, 3],
    "Student_2": [1, 2, 3, 2, 4, 6, 5],
    "Student_3": [3, 4, 2, 5, 6, 7, 4],
    "Student_4": [2, 1, 3, 4, 5, 6, 2],
    "Student_5": [4, 5, 3, 2, 6, 7, 5]
}

days = [1, 2, 3, 4, 5, 6, 7]

plt.xlabel('Days')
plt.ylabel('Study Hours')
plt.title('Trend of a Student Study Time Over a Week')

for student, hours in student_data.items():
    plt.plot(days, hours,label=student)
plt.legend() # --> Shows The Label Name





df = pd.read_csv("enrollment_data.csv")
df


plt.xlabel('Years')
plt.ylabel('Count of Enrollment')
plt.title('Student Enrollment Over (08) Years')

plt.plot(df['Year'], df['Programming'])


plt.xlabel('Years')
plt.ylabel('Count of Enrollment')
plt.title('Student Enrollment Over (08) Years')

for colum in df.columns[1:]:
    plt.plot(df['Year'], df[colum], label=colum)
plt.legend() # We can Pass Location Here



